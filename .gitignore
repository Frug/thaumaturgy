# Personal / runtime data. Scenario examples are copied into here from
# thaumaturgy/defaults/scenarios on first run. Everything a user changes
# (their presets, scenarios, chats) and everything heavy/regenerable (model
# weights, cache) lives under data/ and stays out of version control.
/data/

# NiceGUI per-user storage (contains the session/storage-secret state)
/.nicegui/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/

# OS
.DS_Store
